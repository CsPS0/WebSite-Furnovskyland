<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <!-- Dynamic Title & SEO -->
    <title>Furnovskyland | {{ title }}</title>
    <meta name="description" content="{{ description | default('Welcome to the official website of the National Federation Empire of Furnovskyland!') }}">
    
    <!-- Open Graph Tags -->
    <meta property="og:title" content="Furnovskyland | {{ title }}">
    <meta property="og:description" content="{{ description | default('Welcome to the official website of the National Federation Empire of Furnovskyland!') }}">
    <meta property="og:description" content="Hivatalos weboldal a Furnovskyland államról. Fedezd fel a kultúránkat és közösségünket.">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://csps0.github.io/WebSite-Furnovskyland/IMG/banner.webp">
    
    <link rel="manifest" href="{{ base }}/manifest.json">
    <meta name="theme-color" content="#1e40af">
    
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <!-- Anime.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js"></script>
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="{{ base }}/CSS/source.css">
</head>
<body>
    {% include "header.njk" %}

    <main id="main-content">
        {{ content | safe }}
    </main>
    
    <div id="scroll-to-top" class="scroll-to-top">
        <i class="fas fa-arrow-up"></i>
    </div>

    {% include "footer.njk" %}
</body>
</html>
